# =============================================================================
# Stockbridge Coffee — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Lines marked [REQUIRED] must be set for the app to function.
# Lines marked [OPTIONAL] have sensible defaults.

# --- Server ---
PORT=3001                              # [OPTIONAL] Server port (default: 3001)
ALLOWED_ORIGINS=http://localhost:5173   # [OPTIONAL] CORS allowed origins (comma-separated)

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...          # [REQUIRED] Stripe secret key
STRIPE_WEBHOOK_SECRET=whsec_...        # [REQUIRED] Stripe webhook signing secret

# --- Firebase / Vite (client-side) ---
VITE_FIREBASE_API_KEY=                 # [REQUIRED] Firebase API key
VITE_FIREBASE_AUTH_DOMAIN=             # [REQUIRED] Firebase auth domain
VITE_FIREBASE_PROJECT_ID=              # [REQUIRED] Firebase project ID
VITE_FIREBASE_STORAGE_BUCKET=          # [OPTIONAL] Firebase storage bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=     # [OPTIONAL] Firebase messaging sender ID
VITE_FIREBASE_APP_ID=                  # [REQUIRED] Firebase app ID
VITE_FIREBASE_MEASUREMENT_ID=          # [OPTIONAL] Firebase measurement ID (Analytics)

# --- Stripe (client-side) ---
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...  # [REQUIRED] Stripe publishable key

# --- API URLs (client-side) ---
VITE_API_URL=http://localhost:3001     # [OPTIONAL] Backend API URL
VITE_COPILOT_API_URL=                  # [OPTIONAL] Copilot API URL

# --- Google Maps (client-side) ---
VITE_GOOGLE_MAPS_API_KEY=             # [OPTIONAL] Google Maps API key

# --- Email (SMTP) ---
SMTP_HOST=                             # [OPTIONAL] SMTP host for sending emails
SMTP_PORT=587                          # [OPTIONAL] SMTP port
SMTP_SECURE=false                      # [OPTIONAL] Use TLS
SMTP_USER=                             # [OPTIONAL] SMTP username
SMTP_PASS=                             # [OPTIONAL] SMTP password

# --- GitHub (CMS content) ---
GITHUB_TOKEN=                          # [OPTIONAL] GitHub token for content management
GITHUB_REPO=                           # [OPTIONAL] GitHub repo (owner/repo)

# --- OpenAI ---
OPENAI_API_KEY=                        # [OPTIONAL] OpenAI API key (for AI features)
