# API Keys for AI Video Automation Pipeline

# =======================================================
# RECOMMENDED: Cost-Effective Setup (using your existing subscriptions)
# =======================================================

# Gemini API (you already have subscription!)
# Get your key from: https://aistudio.google.com/app/apikey
# Includes: Image generation + Veo 3.1 video generation
GEMINI_API_KEY=your_gemini_api_key_here

# Eleven Labs (required for voice + sound effects)
# Get your key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Artlist Enterprise API (you already have subscription!)
# Contact: enterprise-api-support@artlist.io
# Includes: Music and SFX library access
ARTLIST_API_KEY=your_artlist_enterprise_api_key_here

# =======================================================
# ALTERNATIVE OPTIONS (if not using Gemini)
# =======================================================

# OpenAI (for image generation with DALL-E)
# Get your key from: https://platform.openai.com/api-keys
# NOTE: ChatGPT subscription ≠ API access, need separate API key
# OPENAI_API_KEY=your_openai_api_key_here

# Pika via Fal.ai (image-to-video, works with Midjourney images)
# Get your key from: https://fal.ai/dashboard/keys
# Good for: Animating Midjourney images
# FAL_API_KEY=your_fal_api_key_here

# Runway ML (full video generation)
# Get your key from: https://runwayml.com/
# RUNWAY_API_KEY=your_runway_api_key_here

# =======================================================
# NO API AVAILABLE
# =======================================================
# Midjourney - No official API, must use manually or unofficial services
